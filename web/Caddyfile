:80 {
	root * /srv
	encode gzip zstd

	# X-Schlussel-Frontend marks this as a genuinely same-origin call - the
	# only origin allowed to receive the session cookie (see the
	# isTrustedOrigin gate in schlussel's own src/routes/auth.ts). Consumer
	# apps' own /auth/* proxies (kuvert, schloss) must NEVER add this.
	handle /auth/* {
		reverse_proxy schlussel:4000 {
			header_up X-Schlussel-Frontend 1
		}
	}

	handle {
		try_files {path} /index.html
		file_server
	}
}
